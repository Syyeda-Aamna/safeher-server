# SafeHer Server Environment Variables
# Copy this file to .env and fill in your actual values

# ===========================================
# DATABASE CONFIGURATION
# ===========================================

# MongoDB Atlas connection string
# Get from: https://cloud.mongodb.com/
# Format: mongodb+srv://username:password@cluster.mongodb.net/database_name
MONGO_URI=mongodb+srv://YOUR_USERNAME:YOUR_PASSWORD@YOUR_CLUSTER.mongodb.net/safeher

# ===========================================
# SECURITY CONFIGURATION
# ===========================================

# JWT secret key (generate a strong random string)
# Generate with: openssl rand -base64 32
JWT_SECRET=REPLACE_WITH_STRONG_RANDOM_SECRET_MIN_32_CHARS

# ===========================================
# SMS CONFIGURATION
# ===========================================

# Fast2SMS API key for sending SMS
# Get from: https://www.fast2sms.com/dev/bulkV2
# 1. Sign up for free account (no credit card required)
# 2. Go to Dashboard -> Dev API -> copy your API key
FAST2SMS_API_KEY=REPLACE_WITH_YOUR_FAST2SMS_API_KEY

# ===========================================
# GOOGLE MAPS CONFIGURATION
# ===========================================

# Google Maps API key for location services
# Get from: https://console.cloud.google.com/apis/credentials
# 1. Create new project or use existing
# 2. Enable Maps JavaScript API, Places API, Geocoding API
# 3. Create API key with $200/month free credit
GOOGLE_MAPS_KEY=REPLACE_WITH_YOUR_GOOGLE_MAPS_API_KEY

# ===========================================
# APPLICATION SETTINGS
# ===========================================

# Application name
APP_NAME=SafeHer

# OTP expiration time in minutes
OTP_EXPIRY_MINUTES=10

# Maximum OTP requests per hour per phone number
MAX_OTP_PER_HOUR=5

# Password hashing rounds (higher = more secure but slower)
BCRYPT_ROUNDS=12

# Rate limit per minute per IP
RATE_LIMIT_PER_MINUTE=60

# Location update interval in minutes
LOCATION_UPDATE_INTERVAL_MINUTES=60

# Maximum check-in timer duration in hours
CHECKIN_TIMER_MAX_HOURS=24

# ===========================================
# SERVER CONFIGURATION
# ===========================================

# Server host (keep as 0.0.0.0 for production)
HOST=0.0.0.0

# Server port (Render.com sets PORT env var)
PORT=8000

# Debug mode (set to False in production)
DEBUG=False

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# ===========================================
# SMS TEMPLATES
# ===========================================

# OTP message template
OTP_MESSAGE_TEMPLATE=Your SafeHer OTP is {otp}. Valid for 10 minutes. Do not share this with anyone.

# SOS alert message template
SOS_MESSAGE_TEMPLATE=EMERGENCY ALERT from {user_name}! She needs help NOW. Location: https://maps.google.com/?q={lat},{lon} | Address: {address} | Time: {time}. Please call her or reach this location immediately. - SafeHer App

# Check-in missed message template
CHECKIN_MISSED_MESSAGE_TEMPLATE=ALERT: {user_name} has NOT checked in safe by {deadline}. Last location: https://maps.google.com/?q={lat},{lon}. Please check on her immediately. - SafeHer App

# ===========================================
# SETUP INSTRUCTIONS
# ===========================================

# STEP 1: MONGODB ATLAS SETUP
# 1. Go to https://cloud.mongodb.com/
# 2. Create free account (no credit card required)
# 3. Create new cluster (M0 free tier)
# 4. Create database user with username/password
# 5. Get connection string from Connect -> Connect your application
# 6. Update MONGO_URI above with your credentials

# STEP 2: FAST2SMS SETUP
# 1. Go to https://www.fast2sms.com/
# 2. Sign up for free account
# 3. Go to Dashboard -> Dev API
# 4. Copy your API key
# 5. Update FAST2SMS_API_KEY above

# STEP 3: GOOGLE MAPS SETUP
# 1. Go to https://console.cloud.google.com/
# 2. Create new project or use existing
# 3. Enable these APIs:
#    - Maps JavaScript API
#    - Places API
#    - Geocoding API
#    - Directions API
# 4. Go to Credentials -> Create Credentials -> API Key
# 5. Restrict key to your domain for security
# 6. Update GOOGLE_MAPS_KEY above

# STEP 4: JWT SECRET SETUP
# 1. Generate strong random secret: openssl rand -base64 32
# 2. Update JWT_SECRET above with generated value

# STEP 5: DEPLOYMENT
# 1. Copy .env.example to .env
# 2. Fill in all the values above
# 3. Deploy to Render.com using render.yaml
# 4. Test API endpoints at https://your-app.onrender.com

# ===========================================
# SECURITY NOTES
# ===========================================

# - Never commit .env file to version control
# - Use strong, unique secrets
# - Restrict API keys to specific domains
# - Enable MongoDB IP whitelisting
# - Monitor API usage and costs
# - Keep all dependencies updated

# ===========================================
# TESTING
# ===========================================

# Test with curl commands:
# curl https://your-app.onrender.com/health
# curl https://your-app.onrender.com/api/auth/register -X POST -H "Content-Type: application/json" -d '{"full_name":"Test User","phone":"9876543210","email":"test@example.com","password":"TestPass123"}'
