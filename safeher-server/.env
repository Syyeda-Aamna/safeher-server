# ===========================================
# APPLICATION SETTINGS
# ===========================================

# Application name
APP_NAME=SafeHer

# OTP expiration time in minutes
OTP_EXPIRY_MINUTES=10

# Maximum OTP requests per hour per phone number
MAX_OTP_PER_HOUR=5

# Password hashing rounds (higher = more secure but slower)
BCRYPT_ROUNDS=12

# Rate limit per minute per IP
RATE_LIMIT_PER_MINUTE=60

# Location update interval in minutes
LOCATION_UPDATE_INTERVAL_MINUTES=60

# Maximum check-in timer duration in hours
CHECKIN_TIMER_MAX_HOURS=24

# ===========================================
# SERVER CONFIGURATION
# ===========================================

# Server host (keep as 0.0.0.0 for production)
HOST=0.0.0.0

# Server port (Render.com sets PORT env var)
PORT=8000

# Debug mode (set to False in production)
DEBUG=False

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
